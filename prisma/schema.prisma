generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("POSTGRES_PRISMA_URL")
  directUrl = env("POSTGRES_URL_NON_POOLING")
}

model PhoneNumber {
  id        String   @id @default(cuid())
  phone     String
  createdAt DateTime @default(now())
}
